{
  "$schema": "https://design-tokens.org/schema",
  "meta": {
    "name": "하나로 가족한마당 Color System",
    "version": "1.0.0",
    "description": "3 palettes and semantic role tokens for the Hanaro Family Festival mobile invitation."
  },
  "palettes": {
    "coral": {
      "label": "Coral · Festival & Warm",
      "ink":          { "value": "#2A1810", "name": "Dark Chestnut" },
      "ink2":         { "value": "#5B3A28", "name": "Cocoa" },
      "muted":        { "value": "#8B6F5E", "name": "Warm Taupe" },
