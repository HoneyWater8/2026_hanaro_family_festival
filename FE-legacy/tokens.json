      "primaryDeep":  { "value": "#C8432A", "name": "Deep Coral" },
      "accent":       { "value": "#E8B93C", "name": "Sun Mustard" },
      "sage":         { "value": "#6B8F5E", "name": "Meadow Sage" },
      "cream":        { "value": "#FFF8EE", "name": "Cream Paper" },
      "paper":        { "value": "#FFFDF8", "name": "Ivory Paper" },
      "line":         { "value": "rgba(42,24,16,0.12)", "name": "Ink Line 12" }
    },
    "hanbok": {
      "label": "Hanbok · Traditional & Formal",
      "ink":          { "value": "#1F2340", "name": "Gamsaek" },
      "ink2":         { "value": "#3B3F6B", "name": "Cheong" },
      "muted":        { "value": "#7B7FA3", "name": "Lavender Mist" },
      "primary":      { "value": "#C23B4A", "name": "Dancheong Red" },
      "primaryDeep":  { "value": "#9B1E2C", "name": "Deep Dancheong" },
      "accent":       { "value": "#D9A441", "name": "Royal Gold" },
      "sage":         { "value": "#3D6A5C", "name": "Celadon" },
      "cream":        { "value": "#F5EEE0", "name": "Hanji Cream" },
      "paper":        { "value": "#FBF6ED", "name": "Hanji Paper" },
      "line":         { "value": "rgba(31,35,64,0.14)", "name": "Navy Line 14" }
    },
    "sage": {
      "label": "Sage · Nature & Calm",
      "ink":          { "value": "#223028", "name": "Forest Ink" },
      "ink2":         { "value": "#3E5544", "name": "Moss" },
      "muted":        { "value": "#7A8D7F", "name": "Sage Fog" },
      "primary":      { "value": "#D97752", "name": "Terracotta" },
      "primaryDeep":  { "value": "#B55A3A", "name": "Deep Terracotta" },
      "accent":       { "value": "#C9A646", "name": "Harvest" },
      "sage":         { "value": "#4F7A5C", "name": "Leaf Green" },
      "cream":        { "value": "#F2EFE4", "name": "Linen" },
      "paper":        { "value": "#FAF8EE", "name": "Parchment" },
      "line":         { "value": "rgba(34,48,40,0.12)", "name": "Forest Line 12" }
    }
  },
  "semantic": {
    "ink":          { "role": "Primary text · titles, numbers" },
    "ink2":         { "role": "Body text, paragraph copy" },
    "muted":        { "role": "Captions, labels, secondary info" },
    "primary":      { "role": "Brand accent · key UI highlights" },
    "primaryDeep":  { "role": "Gradient end, kicker text" },
    "accent":       { "role": "Secondary accent · ornaments" },
    "sage":         { "role": "Natural element · park, success state" },
    "cream":        { "role": "Section background gradients" },
    "paper":        { "role": "Card and container backgrounds" },
    "line":         { "role": "Dividers and subtle borders" }
  }
}
